---
import Layout from '../layouts/Layout.astro';
import heroImg from '../assets/hero-right-img.png';
import zinesImg from '../assets/what-is-zines-img.png';
import girlTreeImg from '../assets/girl-in-tree.png';
import logoImage from '../assets/Amazine_Logo_Simbolo_Tipografia.png';
import gabitoImg from '../assets/gabito.png';
import flipbookPdf from '../assets/AMAZINE_flipbook.pdf';
import { Image } from 'astro:assets';
---

<Layout>
	<!-- Header -->
	<header class="header" id="header">
		<nav class="nav">
			<a href="#sobre">Sobre</a>
			<a href="#inscricao">Inscrição</a>
			<a href="/galeria">Galeria</a>
			<a href="#organizacao">Participantes</a>
		</nav>
	</header>

	<!-- Hero Section -->
	<section class="hero" id="hero">
		<div class="hero-left">
			<div class="hero-logo-container">
				<Image src={logoImage} alt="AMAZINE" class="hero-logo" />
				<a href="https://instagram.com/feiraamazine" target="_blank" rel="noopener" class="instagram-link" aria-label="Instagram">
					<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
						<rect x="2" y="2" width="20" height="20" rx="5"/>
						<circle cx="12" cy="12" r="4"/>
						<circle cx="18" cy="6" r="1.5" fill="currentColor"/>
					</svg>
				</a>
			</div>

			<div class="hero-date-banner">
				<span>6 de março de 2026</span>
				<span class="separator mobile-hidden">—</span>
				<span>Biblioteca Elcy Lacerda</span>
			</div>
		</div>

		<div class="hero-right">
			<p class="hero-text">
				A 1ª Feira de zines de Macapá — AMAZINE objetiva valorizar e fazer circular a produção literária e artística independente de Macapá a partir de fanzines, gênero textual de grande relevância cultural, social e política.
			</p>
			<Image src={heroImg} alt="Mão segurando um zine" class="hero-image" />
		</div>
	</section>

	<!-- O que são zines -->
	<section class="zines-section" id="sobre">
		<div class="zines-container">
			<div class="zines-image">
				<Image src={zinesImg} alt="Ilustração de um zine aberto" />
			</div>
			<div class="zines-content">
				<h2>O que são zines?</h2>
				<p>São publicações independentes, de pouca tiragem, feitas artesanalmente e até digitalmente sobre assuntos de interesses diversos: literatura, arte, música, política, cinema e mais.</p>
				<p class="zines-cta-text">Conheça no botão a seguir a iniciativa Biblioteca de Zines, acervo digital para zines brasileiras</p>
				<a href="https://www.biblioteca-de-zines.com.br/" target="_blank" rel="noopener" class="btn-primary">
					Acessar
				</a>
			</div>
		</div>
	</section>

	<!-- Quote Section -->
	<section class="quote-section">
		<div class="quote-left">
			<h2>Um espaço para divulgar e apreciar a variedade de produções de autorias locais</h2>
			<p class="quote-location">Macapá — Amazônia — Brasil</p>
		</div>
		<div class="quote-right">
			<Image src={girlTreeImg} alt="Ilustração de uma garota em uma árvore" />
		</div>
	</section>

	<!-- PDF Flipbook Section -->
	<section class="flipbook-section">
		<div class="flipbook-container">
			<span class="section-label">Memórias Digitais</span>
			<h2>Primeira Edição da Feira AMAZINE</h2>
		<iframe allowfullscreen="allowfullscreen" allow="clipboard-write" scrolling="no" class="fp-iframe" src="https://heyzine.com/flip-book/883ef441dd.html" style="border: 1px solid lightgray; width: 100%; height: 400px;"></iframe>
		</div>
	</section>

	<!-- Oficina Section -->
	<section class="workshop-section" id="inscricao">
		<div class="workshop-hero">
			<span class="section-label">Oficina</span>
			<h2>Workshop de Criação de Zines</h2>
			<p class="workshop-subtitle">Uma experiência transformadora de criação artística e literária</p>
		</div>
		
		<div class="workshop-main">
			<div class="workshop-poster-large">
				<Image src={gabitoImg} alt="Poster da Oficina de Zines com Gabito Alencar" class="poster-image-large" />
			</div>
			
			<div class="workshop-content-large">
				<div class="workshop-status">
					<span class="workshop-badge">REALIZADA</span>
					<span class="workshop-date">6 de março • 9h-11h</span>
				</div>
				
				<div class="workshop-description">
					<h3>Sobre o Workshop</h3>
					<p>Workshop prático onde os participantes aprenderam técnicas para criação de zines, usando materiais simples e acessíveis. Durante duas horas intensivas, exploramos desde conceitos básicos até técnicas avançadas de produção artesanal.</p>
					<p>A oficina abordou temas como narrativa visual, técnicas de colagem, impressão artesanal e distribuição independente, proporcionando uma experiência completa no universo dos zines.</p>
				</div>
				
				<div class="workshop-facilitator-large">
					<div class="facilitator-info">
						<h4>Oficineiro</h4>
						<h5>Gabito Alencar</h5>
					</div>
				</div>
				
				<div class="workshop-actions">
					<a href="/galeria" class="btn-primary btn-large">
						<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
							<circle cx="9" cy="9" r="2"/>
							<path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/>
						</svg>
						Ver fotos da oficina
					</a>
					<span class="workshop-note">Confira os momentos especiais registrados durante a oficina</span>
				</div>
			</div>
		</div>
	</section>

	<!-- Organização Section -->
	<section class="organizacao-section" id="organizacao">
		<h2>Organização</h2>
		<div class="organizacao-list">
			<a href="https://www.instagram.com/luana.g.m/" target="_blank" rel="noopener">Luana Góes</a>
			<a href="https://www.instagram.com/jenifferyara_/" target="_blank" rel="noopener">Jeniffer Yara</a>
			<a href="https://www.instagram.com/coletivoventosdonorte/" target="_blank" rel="noopener">Coletivo Ventos do Norte</a>
		</div>
	</section>

	<!-- Footer -->
	<footer class="footer">
		<div class="footer-container">
			<div class="footer-brand">
				<Image src={logoImage} alt="AMAZINE" class="footer-logo" />
				<p>Feira de Zines de Macapá<br/>Primeira Edição — 2026</p>
			</div>
			<div class="footer-info">
				<p id="highlight">6 de Março de 2026<br/>Biblioteca Elcy Lacerda, Macapá</p>
			</div>
			<div class="footer-links">
				<a href="mailto:feiraamazine@gmail.com">feiraamazine@gmail.com</a>
				<a href="https://instagram.com/feiraamazine" target="_blank" rel="noopener">@feiraamazine</a>
			</div>
		</div>
	</footer>
</Layout>

<style>
	/* =============================================
	   COLORS
	   ============================================= */
	:root {
		--cream: #FAF6F1;
		--wine: #5C232A;
		--wine-dark: #4A1D22;
		--olive: #4A5A2B;
		--orange: #E07B3C;
	}

	/* =============================================
	   HEADER - Framer-level sticky nav
	   ============================================= */
	.header {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 100;
		padding: 1rem 2rem;
		background: rgba(250, 246, 241, 0);
		backdrop-filter: blur(0px);
		-webkit-backdrop-filter: blur(0px);
		transition:
			background 0.4s cubic-bezier(0.16, 1, 0.3, 1),
			backdrop-filter 0.4s cubic-bezier(0.16, 1, 0.3, 1),
			-webkit-backdrop-filter 0.4s cubic-bezier(0.16, 1, 0.3, 1),
			box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1),
			padding 0.4s cubic-bezier(0.16, 1, 0.3, 1);
	}

	.header.scrolled {
		background: rgba(250, 246, 241, 0.85);
		backdrop-filter: blur(12px) saturate(180%);
		-webkit-backdrop-filter: blur(12px) saturate(180%);
		box-shadow:
			0 1px 0 rgba(92, 35, 42, 0.06),
			0 4px 20px rgba(92, 35, 42, 0.04);
		padding: 0.875rem 2rem;
	}

	.header .nav {
		display: flex;
		gap: 2rem;
	}

	.header .nav a {
		font-size: 0.9375rem;
		font-weight: 500;
		color: var(--wine);
		transition: color 0.2s ease, opacity 0.2s ease;
		position: relative;
	}

	.header .nav a::after {
		content: '';
		position: absolute;
		bottom: -4px;
		left: 0;
		width: 0;
		height: 1.5px;
		background: var(--wine);
		transition: width 0.3s cubic-bezier(0.16, 1, 0.3, 1);
	}

	.header .nav a:hover::after {
		width: 100%;
	}

	.header .nav a:hover {
		opacity: 0.8;
	}

	/* =============================================
	   HERO SECTION
	   ============================================= */
	.hero {
		display: grid;
		grid-template-columns: 1fr 1fr;
		min-height: 500px;
		margin: 6rem 2rem 2rem;
		border-radius: 12px;
		overflow: hidden;
		box-shadow: 0 8px 32px rgba(92, 35, 42, 0.15);
	}

	.hero-left {
		background: var(--cream);
		display: flex;
		flex-direction: column;
		padding: 2rem;
		position: relative;
	}
	.hero-logo {
		max-width: 80%;
	}
	.hero-logo-container {
		display: flex;
		align-items: center;
		flex-direction: column;
		gap: 1rem;
		margin-bottom: 2rem;
	}
	.instagram-link {
		color: var(--wine);
		transition: opacity 0.2s;
	}

	.instagram-link:hover {
		opacity: 0.7;
	}

	.hero-date-banner {
		margin-top: auto;
		background: var(--wine);
		color: white;
		padding: 1rem 1.5rem;
		font-size: 2rem;
		display: flex;
		align-items: center;
		gap: 0.75rem;
		margin-left: -2rem;
		margin-right: -2rem;
		margin-bottom: -2rem;
		padding-left: 2rem;
	}

	.hero-date-banner .separator {
		opacity: 0.5;
	}

	.hero-right {
		background: var(--wine);
		color: white;
		padding: 2rem;
		display: flex;
		flex-direction: column;
	}

	.hero-text {
		font-size: 1.5rem;
		line-height: 1.7;
		color: white;
		max-width: 360px;
		margin-bottom: auto;
	}

	.hero-image {
		max-width: 80%;
		margin-top: auto;
		align-self: center;
	}

	/* =============================================
	   ZINES SECTION
	   ============================================= */
	.zines-section {
		background: var(--cream);
		padding: 6rem 2rem;
	}

	.zines-container {
		max-width: 1000px;
		margin: 0 auto;
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 4rem;
		align-items: center;
	}

	.zines-image img {
		max-width: 100%;
	}

	.zines-content {
		text-align: center;
	}

	.zines-content h2 {
		font-size: 1.5rem;
		color: var(--wine);
		margin-bottom: 1.5rem;
	}

	.zines-content p {
		font-size: 1rem;
		line-height: 1.7;
		color: var(--wine);
		margin-bottom: 1rem;
	}

	.zines-cta-text {
		font-size: 0.9375rem;
		margin-bottom: 1.5rem;
	}

	.btn-primary {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.875rem 2.5rem;
		background: var(--orange);
		color: white;
		font-family: var(--font-body);
		font-size: 1rem;
		font-weight: 600;
		border: none;
		border-radius: 4px;
		cursor: pointer;
		transition: background 0.2s, transform 0.2s;
	}

	.btn-primary:hover {
		background: #c96a32;
		transform: translateY(-1px);
	}

	.btn-block {
		width: 100%;
	}
	.btn-disabled,
	.btn-disabled:hover,
	.btn-disabled:focus {
		background: #cccccc;
		color: #666666;
		cursor: not-allowed;
		transform: none;
	}

	/* =============================================
	   QUOTE SECTION
	   ============================================= */
	.quote-section {
		display: grid;
		grid-template-columns: 1fr 1fr;
		min-height: 500px;
	}

	.quote-left {
		background: var(--olive);
		color: white;
		padding: 4rem;
		display: flex;
		flex-direction: column;
		justify-content: center;
	}

	.quote-left h2 {
		font-size: clamp(1.75rem, 3vw, 2.5rem);
		font-weight: 600;
		line-height: 1.2;
		margin-bottom: 2rem;
	}

	.quote-location {
		font-size: 1rem;
		color: rgba(255, 255, 255, 0.8);
	}

	.quote-right {
		background: var(--cream);
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 2rem;
	}

	.quote-right img {
		max-width: 100%;
		max-height: 100%;
		object-fit: contain;
	}

	/* =============================================
	   FLIPBOOK SECTION
	   ============================================= */
	.flipbook-section {
		background: white;
		padding: 6rem 2rem;
	}

	.flipbook-container {
		max-width: 800px;
		margin: 0 auto;
		text-align: center;
	}

	.flipbook-container .section-label {
		display: block;
		font-size: 0.75rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--orange);
		margin-bottom: 0.75rem;
	}

	.flipbook-container h2 {
		font-size: 2rem;
		color: var(--wine);
		margin-bottom: 1rem;
	}

	.flipbook-container > p {
		font-size: 1.125rem;
		color: var(--wine);
		opacity: 0.8;
		margin-bottom: 3rem;
		max-width: 600px;
		margin-left: auto;
		margin-right: auto;
	}

	.flipbook-card {
		background: var(--cream);
		border-radius: 16px;
		padding: 3rem 2rem;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 2rem;
		box-shadow: 0 4px 20px rgba(92, 35, 42, 0.08);
	}

	.flipbook-preview {
		text-align: center;
	}

	.flipbook-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 80px;
		height: 80px;
		background: var(--wine);
		color: white;
		border-radius: 50%;
		margin-bottom: 1.5rem;
	}

	.flipbook-preview h3 {
		font-size: 1.5rem;
		color: var(--wine);
		margin-bottom: 1rem;
	}

	.flipbook-preview p {
		font-size: 1rem;
		color: var(--wine);
		line-height: 1.6;
		max-width: 400px;
	}

	.flipbook-actions {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1rem;
	}

	.btn-flipbook {
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	.flipbook-status {
		font-size: 0.875rem;
		color: var(--wine);
		opacity: 0.6;
		font-style: italic;
	}

	/* =============================================
	   WORKSHOP SECTION
	   ============================================= */
	.workshop-section {
		background: var(--cream);
		padding: 6rem 0;
	}

	.workshop-hero {
		text-align: center;
		padding: 0 2rem 4rem;
		max-width: 800px;
		margin: 0 auto;
	}

	.workshop-hero .section-label {
		display: block;
		font-size: 0.75rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--orange);
		margin-bottom: 0.75rem;
	}

	.workshop-hero h2 {
		font-size: clamp(2rem, 4vw, 3rem);
		color: var(--wine);
		margin-bottom: 1rem;
		font-weight: 600;
	}

	.workshop-subtitle {
		font-size: 1.25rem;
		color: var(--wine);
		opacity: 0.8;
		font-weight: 400;
	}

	.workshop-main {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 2rem;
		display: grid;
		grid-template-columns: 400px 1fr;
		gap: 4rem;
		align-items: start;
	}

	.workshop-poster-large {
		position: sticky;
		top: 2rem;
	}

	.poster-image-large {
		width: 100%;
		height: auto;
		border-radius: 16px;
		box-shadow: 0 8px 32px rgba(92, 35, 42, 0.2);
	}

	.workshop-content-large {
		background: white;
		border-radius: 20px;
		padding: 3rem;
		box-shadow: 0 4px 24px rgba(92, 35, 42, 0.08);
	}

	.workshop-status {
		display: flex;
		align-items: center;
		gap: 1rem;
		margin-bottom: 2rem;
		flex-wrap: wrap;
	}

	.workshop-badge {
		background: var(--olive);
		color: white;
		font-size: 0.875rem;
		font-weight: 700;
		padding: 0.5rem 1rem;
		border-radius: 20px;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.workshop-date {
		font-size: 1rem;
		color: var(--wine);
		font-weight: 500;
	}

	.workshop-description h3 {
		font-size: 1.5rem;
		color: var(--wine);
		margin-bottom: 1.5rem;
		font-weight: 600;
	}

	.workshop-description p {
		font-size: 1rem;
		color: var(--wine);
		line-height: 1.7;
		margin-bottom: 1rem;
	}

	.workshop-description p:last-child {
		margin-bottom: 2rem;
	}

	.workshop-facilitator-large {
		background: rgba(74, 90, 43, 0.03);
		border-left: 4px solid var(--olive);
		border-radius: 8px;
		padding: 2rem;
		margin: 2rem 0;
	}

	.facilitator-info h4 {
		font-size: 0.875rem;
		color: var(--olive);
		text-transform: uppercase;
		letter-spacing: 0.05em;
		font-weight: 700;
		margin-bottom: 0.5rem;
	}

	.facilitator-info h5 {
		font-size: 1.25rem;
		color: var(--wine);
		margin-bottom: 0.75rem;
		font-weight: 600;
	}

	.facilitator-info p {
		font-size: 0.9375rem;
		color: var(--wine);
		line-height: 1.6;
		margin: 0;
	}

	.workshop-actions {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.btn-large {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		padding: 1rem 2rem;
		font-size: 1.0625rem;
		font-weight: 600;
	}

	.workshop-note {
		font-size: 0.875rem;
		color: var(--wine);
		opacity: 0.7;
		font-style: italic;
	}

	/* =============================================
	   ORGANIZAÇÃO SECTION
	   ============================================= */
	.organizacao-section {
		background: var(--wine);
		color: white;
		padding: 4rem 2rem;
		text-align: center;
	}

	.organizacao-section h2 {
		font-size: 2rem;
		margin-bottom: 2rem;
	}

	.organizacao-list {
		display: flex;
		justify-content: center;
		gap: 3rem;
		flex-wrap: wrap;
	}

	.organizacao-list a {
		font-size: 1.125rem;
		color: white;
		text-decoration: underline;
		text-underline-offset: 4px;
		text-decoration-thickness: 1px;
		opacity: 0.9;
		transition: opacity 0.2s ease;
	}

	.organizacao-list a:hover {
		opacity: 1;
	}

	/* =============================================
	   FOOTER
	   ============================================= */
	.footer {
		padding: 4rem 2rem;
		background: var(--gray-900, #18181b);
		color: white;
	}

	.footer-container {
		max-width: 1120px;
		margin: 0 auto;
		display: grid;
		gap: 2rem;
	}

	.footer-logo {
		width: 100px;
		filter: brightness(0) invert(1);
		opacity: 0.9;
		margin-bottom: 1rem;
	}

	.footer-brand p,
	.footer-info p {
		font-size: 0.875rem;
		color: #a1a1aa;
		line-height: 1.6;
	}

	.footer-links {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.footer-links a {
		font-size: 0.875rem;
		color: #a1a1aa;
		transition: color 0.15s ease;
	}

	.footer-links a:hover {
		color: white;
	}

	/* =============================================
	   RESPONSIVE
	   ============================================= */
	.mobile-hidden {
		display: none;
	}

	@media (min-width: 600px) {
		.mobile-hidden {
			display: inline;
		}
	}
	@media (max-width: 900px) {
		.hero {
			grid-template-columns: 1fr;
			margin: 6rem 1rem 2rem;
			min-height: auto;
		}

		.hero-left {
			min-height: 40vh;
		}

		.hero-right {
			min-height: 50vh;
		}

		.hero-date-banner {
			position: relative;
			margin-left: -2rem;
			margin-right: -2rem;
		}

		.zines-container {
			grid-template-columns: 1fr;
			gap: 2rem;
